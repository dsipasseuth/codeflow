# =========================
# Repository cache (Bazel 9)
# =========================
build --repo_contents_cache=~/.bazel/repo_cache

# =========================
# JAVA TOOLCHAIN SPLIT
# =========================
build --java_runtime_version=remotejdk_25
run --java_runtime_version=remotejdk_25
test --java_runtime_version=remotejdk_25

build --java_language_version=25
test --java_language_version=25

# =========================
# Test configuration
# =========================
test --test_output=errors

# JUnit 5 exit handling (your custom flag)
test --jvmopt=-Dcom.github.bazel_contrib.contrib_rules_jvm.junit5.allow_exit=true

# Java 25 security manager removal (correct for modern JDKs)
test --jvmopt=-Djava.security.manager=disallow